
from fastapi import FastAPI, Request
from app.avito_events import handle_avito_event
from app.avito_webhooks import subscribe_webhook
import logging
import asyncio
import httpx
import os
from app.telegram import send_telegram_message
from app.avito_oauth import get_access_token
from app.config import (USER_ID)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s | %(levelname)s | %(name)s | %(message)s"
)

logger = logging.getLogger("avito-bot")
AVITO_API = "https://api.avito.ru"
app = FastAPI()

@app.on_event("startup")
async def startup_event():
  logger.info("🚀 Приложение запущено. Старт polling_worker")
  asyncio.create_task(polling_worker())

async def get_chats(token):
  logger.info("📥 Запрос списка чатов (unread_only=True)")
  async with httpx.AsyncClient(timeout=30) as client:
    response = await client.get(
      f"{AVITO_API}/messenger/v2/accounts/{USER_ID}/chats",
      headers={"Authorization": f"Bearer {token}"},
      params={"unread_only": True}
    )

    logger.info("📥 get_chats HTTP %s", response.status_code)
    logger.info("📥 BODY: %s", response.text)
    return response.json().get("chats", [])

async def get_messages(token, chat_id):
  logger.info("📨 Запрос сообщений для чата %s", chat_id)
  async with httpx.AsyncClient() as client:
    response = await client.get(
      f"{AVITO_API}/messenger/v3/accounts/{USER_ID}/chats/{chat_id}/messages",
      headers={"Authorization": f"Bearer {token}"}
    )
    logger.info("📨 get_messages HTTP %s", response.status_code)
    return response.json().get("messages", [])

async def polling_worker():
  logger.info("🔐 Получаем access_token")
  token = await get_access_token()
  logger.info("✅ Токен получен успешно")
  timer = 86400
  while True:
    try:
      logger.info("🔄 Проверка новых сообщений Avito...")
      chats = await get_chats(token)

      for chat in chats:
        chat_id = chat["id"]
        messages = await get_messages(token, chat_id)

        for message in messages:
          if message.get("direction") == "in":
            text = message.get("content", {}).get("text")
            logger.info("Сообщение отправляется в телеграм!")
            if text:
              await send_telegram_message(
                f"📩 Новое сообщение Avito\n\n"
                f"💬 chat_id: {chat_id}\n\n{text}"
              )

    except Exception as e:
      print("❌ Ошибка polling:", e)

    await asyncio.sleep(120)
    timer -= 120
    if timer <= 0:
      token = await get_access_token()
      timer = 86400

def parse_chat_info(chat: dict, my_user_id: int):
    item = chat.get("context", {}).get("value", {})

    item_title = item.get("title")
    item_url = item.get("url")
    item_price = item.get("price_string")
    location = item.get("location", {}).get("title")

    users = chat.get("users", [])
    client = next((u for u in users if u["id"] != my_user_id), None)

    if not client:
        return None

    client_name = client.get("name")
    avatar = client.get("public_user_profile", {}) \
                   .get("avatar", {}) \
                   .get("images", {}) \
                   .get("256x256")

    return {
        "chat_id": chat.get("id"),
        "item_title": item_title,
        "item_url": item_url,
        "item_price": item_price,
        "location": location,
        "client_name": client_name,
        "avatar": avatar,
    }
